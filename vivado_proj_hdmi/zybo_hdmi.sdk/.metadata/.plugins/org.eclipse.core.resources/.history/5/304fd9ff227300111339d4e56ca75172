// --- ESTRUTURAS DO JOGO ---
typedef struct {
    int x, y;
    int w, h;
    int speed;
    int active;
    const u32 *sprite;
} Entity;

Entity frog;
Entity cars[6];
Entity logs[6];
int btn_cooldown = 0;

// --- INICIALIZAÇĂO DE HARDWARE ---
void init_hardware() {
    XAxiVdma_Config *Config = XAxiVdma_LookupConfig(XPAR_AXIVDMA_0_DEVICE_ID);
    XAxiVdma_CfgInitialize(&Vdma, Config, Config->BaseAddress);

    XAxiVdma_DmaSetup ReadCfg;
    ReadCfg.VertSizeInput = FRAME_HEIGHT;
    ReadCfg.HoriSizeInput = FRAME_WIDTH * PIXEL_BYTES;
    ReadCfg.Stride = FRAME_WIDTH * PIXEL_BYTES;
    ReadCfg.FrameDelay = 0;
    ReadCfg.EnableCircularBuf = 1;
    ReadCfg.EnableSync = 0;
    ReadCfg.PointNum = 0;
    ReadCfg.EnableFrameCounter = 0;
    ReadCfg.FixedFrameStoreAddr = 0;

    XAxiVdma_DmaConfig(&Vdma, XAXIVDMA_READ, &ReadCfg);
    XAxiVdma_DmaSetBufferAddr(&Vdma, XAXIVDMA_READ, (UINTPTR[]){BUFFER_0_ADDR, BUFFER_1_ADDR});
    XAxiVdma_DmaStart(&Vdma, XAXIVDMA_READ);

    XGpio_Initialize(&Gpio, XPAR_AXI_GPIO_0_DEVICE_ID);
}

void swap_buffers() {
    current_buffer = (current_buffer == 0) ? 1 : 0;
    draw_buffer = (u32 *)(current_buffer == 0 ? BUFFER_0_ADDR : BUFFER_1_ADDR);
    XAxiVdma_StartParking(&Vdma, current_buffer, XAXIVDMA_READ);
    Xil_DCacheFlushRange((UINTPTR)draw_buffer, FRAME_SIZE);
}

// --- FUNÇŐES DE DESENHO ---
void draw_rect(int x, int y, int w, int h, u32 color) {
    for (int i = 0; i < h; i++) {
        for (int j = 0; j < w; j++) {
            if (x + j >= 0 && x + j < FRAME_WIDTH && y + i >= 0 && y + i < FRAME_HEIGHT) {
                draw_buffer[(y + i) * FRAME_WIDTH + (x + j)] = color;
            }
        }
    }
}

// Desenha sprite 16x16 redimensionado para 32x32 (Pixel art blocky)
void draw_sprite(int x, int y, int w, const u32 *sprite_data) {
    int scale = w / 16;
    for (int i = 0; i < 16; i++) {
        for (int j = 0; j < 16; j++) {
            u32 color = sprite_data[i * 16 + j];
            if (color != COLOR_TRANS) {
                // Desenha o pixel escalado (bloco de 2x2 ou 3x3)
                for (int dy = 0; dy < scale; dy++) {
                    for (int dx = 0; dx < scale; dx++) {
                        int px = x + (j * scale) + dx;
                        int py = y + (i * scale) + dy;
                        if (px >= 0 && px < FRAME_WIDTH && py >= 0 && py < FRAME_HEIGHT) {
                            draw_buffer[py * FRAME_WIDTH + px] = color;
                        }
                    }
                }
            }
        }
    }
}

// --- LÓGICA E FÍSICA DO JOGO ---
void reset_frog() {
    frog.x = FRAME_WIDTH / 2 - 16;
    frog.y = 420;
}

void init_game() {
    frog.w = 32; frog.h = 32; frog.sprite = SPRITE_FROG;
    reset_frog();

    // Inicializa Carros (2 faixas, indo para a esquerda e direita)
    for (int i = 0; i < 6; i++) {
        cars[i].w = 32; cars[i].h = 32; cars[i].sprite = SPRITE_CAR;
        cars[i].y = 350 - (i % 2) * 50;
        cars[i].x = i * 150;
        cars[i].speed = (i % 2 == 0) ? 3 : -4;
    }

    // Inicializa Troncos (2 faixas sobre a água)
    for (int i = 0; i < 6; i++) {
        logs[i].w = 64; // Tronco é mais largo (esticamos a renderizaçăo ou botamos 2 seguidos)
        logs[i].h = 32; logs[i].sprite = SPRITE_LOG;
        logs[i].y = 150 - (i % 2) * 50;
        logs[i].x = i * 180;
        logs[i].speed = (i % 2 == 0) ? 2 : -3;
    }
}

int check_collision(int x1, int y1, int w1, int h1, int x2, int y2, int w2, int h2) {
    // Reduz um pouco o hitbox (bounding box) para perdoar raspar nos carros
    int shrink = 4;
    return (x1 + shrink < x2 + w2 - shrink) && (x1 + w1 - shrink > x2 + shrink) &&
           (y1 + shrink < y2 + h2 - shrink) && (y1 + h1 - shrink > y2 + shrink);
}

void update_game() {
    u32 buttons = XGpio_DiscreteRead(&Gpio, 1);

    // Controle do Sapo (Pulo de 32 em 32 pixels com Cooldown para năo voar)
    if (btn_cooldown == 0) {
        if (buttons & 0x1) { frog.x += 32; btn_cooldown = 10; } // Right
        if (buttons & 0x2) { frog.x -= 32; btn_cooldown = 10; } // Left
        if (buttons & 0x4) { frog.y += 32; btn_cooldown = 10; } // Down
        if (buttons & 0x8) { frog.y -= 32; btn_cooldown = 10; } // Up
    } else {
        btn_cooldown--;
    }

    // Limites da tela
    if (frog.x < 0) frog.x = 0;
    if (frog.x > FRAME_WIDTH - 32) frog.x = FRAME_WIDTH - 32;
    if (frog.y > 420) frog.y = 420; // Chao inicial
    if (frog.y < 30) reset_frog();  // Venceu a fase!

    // Atualiza Carros e Troncos
    for (int i = 0; i < 6; i++) {
        cars[i].x += cars[i].speed;
        if (cars[i].speed > 0 && cars[i].x > FRAME_WIDTH) cars[i].x = -64;
        if (cars[i].speed < 0 && cars[i].x < -64) cars[i].x = FRAME_WIDTH;

        logs[i].x += logs[i].speed;
        if (logs[i].speed > 0 && logs[i].x > FRAME_WIDTH) logs[i].x = -128;
        if (logs[i].speed < 0 && logs[i].x < -128) logs[i].x = FRAME_WIDTH;
    }

    // Colisăo com Carros
    for (int i = 0; i < 6; i++) {
        if (check_collision(frog.x, frog.y, frog.w, frog.h, cars[i].x, cars[i].y, cars[i].w, cars[i].h)) {
            reset_frog(); // Splat!
        }
    }

    // Lógica da Água e Troncos
    if (frog.y >= 50 && frog.y <= 200) { // Sapo está na zona da água
        int on_log = 0;
        for (int i = 0; i < 6; i++) {
            if (check_collision(frog.x, frog.y, frog.w, frog.h, logs[i].x, logs[i].y, logs[i].w, logs[i].h)) {
                on_log = 1;
                frog.x += logs[i].speed; // Carregado pelo tronco
                break;
            }
        }
        if (!on_log) reset_frog(); // Caiu na água! Afundou.
    }
}

void render_game() {
    // Fundo
    draw_rect(0, 0, FRAME_WIDTH, 50, COLOR_SAFE);          // Chegada
    draw_rect(0, 50, FRAME_WIDTH, 170, COLOR_WATER);       // Rio
    draw_rect(0, 220, FRAME_WIDTH, 60, COLOR_SAFE);        // Calçada do meio
    draw_rect(0, 280, FRAME_WIDTH, 120, COLOR_ROAD);       // Asfalto
    draw_rect(0, 400, FRAME_WIDTH, 80, COLOR_SAFE);        // Calçada Inicial

    // Entidades
    for (int i = 0; i < 6; i++) {
        // Troncos (desenhamos 2 tiles juntos para fazer um tronco comprido)
        draw_sprite(logs[i].x, logs[i].y, 32, logs[i].sprite);
        draw_sprite(logs[i].x + 32, logs[i].y, 32, logs[i].sprite);

        // Carros
        draw_sprite(cars[i].x, cars[i].y, 32, cars[i].sprite);
    }

    // Sapo por último para ficar por cima de tudo
    draw_sprite(frog.x, frog.y, 32, frog.sprite);

    swap_buffers();
}

int main() {
    init_hardware();
    init_game();

    while (1) {
        update_game();
        render_game();
        usleep(16000); // Frame limit ~60 FPS
    }

    return 0;
}
