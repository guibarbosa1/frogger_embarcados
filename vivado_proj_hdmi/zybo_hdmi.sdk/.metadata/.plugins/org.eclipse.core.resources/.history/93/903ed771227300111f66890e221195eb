#include <stdio.h>
#include "xparameters.h"
#include "xaxivdma.h"
#include "xil_cache.h"
#include "xgpio.h"
#include "sleep.h"

// Resoluçăo definida no seu hardware (v_tc_0)
#define FRAME_WIDTH  640
#define FRAME_HEIGHT 480
#define PIXEL_BYTES  4
#define FRAME_SIZE   (FRAME_WIDTH * FRAME_HEIGHT * PIXEL_BYTES)

// Endereços na memória DDR para os dois buffers
#define BUFFER_0_ADDR 0x10000000
#define BUFFER_1_ADDR (BUFFER_0_ADDR + FRAME_SIZE)

// Cor de transparęncia para os sprites (ex: Magenta)
#define COLOR_TRANSPARENT 0x00FF00FF

XAxiVdma Vdma;
XGpio Gpio;

// Variável para rastrear qual buffer está sendo exibido
int current_buffer = 0;
u32 *draw_buffer = (u32 *)BUFFER_0_ADDR;

// Estrutura básica para entidades do jogo
typedef struct {
    int x, y;
    int width, height;
    int speed;
    const u32 *sprite; // Ponteiro para o array do sprite
} Entity;

Entity frog;

// --- FUNÇŐES DE HARDWARE ---

void init_hardware() {
    XAxiVdma_Config *Config = XAxiVdma_LookupConfig(XPAR_AXIVDMA_0_DEVICE_ID);
    XAxiVdma_CfgInitialize(&Vdma, Config, Config->BaseAddress);

    XAxiVdma_DmaSetup ReadCfg;
    ReadCfg.VertSizeInput = FRAME_HEIGHT;
    ReadCfg.HoriSizeInput = FRAME_WIDTH * PIXEL_BYTES;
    ReadCfg.Stride = FRAME_WIDTH * PIXEL_BYTES;
    ReadCfg.FrameDelay = 0;
    ReadCfg.EnableCircularBuf = 1;
    ReadCfg.EnableSync = 0;
    ReadCfg.PointNum = 0;
    ReadCfg.EnableFrameCounter = 0;
    ReadCfg.FixedFrameStoreAddr = 0;

    XAxiVdma_DmaConfig(&Vdma, XAXIVDMA_READ, &ReadCfg);
    XAxiVdma_DmaSetBufferAddr(&Vdma, XAXIVDMA_READ, (UINTPTR[]){BUFFER_0_ADDR, BUFFER_1_ADDR});
    XAxiVdma_DmaStart(&Vdma, XAXIVDMA_READ);

    XGpio_Initialize(&Gpio, XPAR_AXI_GPIO_0_DEVICE_ID);
}

void swap_buffers() {
    // Atualiza o ponteiro de desenho para o buffer oculto
    if (current_buffer == 0) {
        draw_buffer = (u32 *)BUFFER_1_ADDR;
        current_buffer = 1;
    } else {
        draw_buffer = (u32 *)BUFFER_0_ADDR;
        current_buffer = 0;
    }
    // Diz ao VDMA para ler do buffer que acabamos de terminar de desenhar
    XAxiVdma_StartParking(&Vdma, current_buffer, XAXIVDMA_READ);
    Xil_DCacheFlushRange((UINTPTR)draw_buffer, FRAME_SIZE);
}

// --- FUNÇŐES GRÁFICAS ---

void draw_rect(int x, int y, int w, int h, u32 color) {
    for (int i = 0; i < h; i++) {
        for (int j = 0; j < w; j++) {
            if (x + j >= 0 && x + j < FRAME_WIDTH && y + i >= 0 && y + i < FRAME_HEIGHT) {
                draw_buffer[(y + i) * FRAME_WIDTH + (x + j)] = color;
            }
        }
    }
}

void draw_sprite(int x, int y, int w, int h, const u32 *sprite_data) {
    for (int i = 0; i < h; i++) {
        for (int j = 0; j < w; j++) {
            if (x + j >= 0 && x + j < FRAME_WIDTH && y + i >= 0 && y + i < FRAME_HEIGHT) {
                u32 pixel = sprite_data[i * w + j];
                if (pixel != COLOR_TRANSPARENT) {
                    draw_buffer[(y + i) * FRAME_WIDTH + (x + j)] = pixel;
                }
            }
        }
    }
}

// --- LÓGICA DO JOGO ---

void update_game() {
    u32 buttons = XGpio_DiscreteRead(&Gpio, 1);

    // Movimentaçăo básica do sapo baseada nos botőes da placa (ajuste conforme sua pinagem)
    if (buttons & 0x1) frog.x += frog.speed; // Direita
    if (buttons & 0x2) frog.x -= frog.speed; // Esquerda
    if (buttons & 0x4) frog.y += frog.speed; // Baixo
    if (buttons & 0x8) frog.y -= frog.speed; // Cima
}

void render_game() {
    // 1. Limpa a tela (fundo preto)
    draw_rect(0, 0, FRAME_WIDTH, FRAME_HEIGHT, 0x00000000);

    // 2. Desenha o cenário (ex: rio azul, grama verde)
    draw_rect(0, 50, FRAME_WIDTH, 200, 0x000000FF); // Rio

    // 3. Desenha entidades (Aqui entraria o draw_sprite usando o array do sapo)
    draw_rect(frog.x, frog.y, frog.width, frog.height, 0x0000FF00); // Placeholder do Sapo

    // 4. Troca os buffers para exibir o frame na tela
    swap_buffers();
}

int main() {
    init_hardware();

    frog.x = 300;
    frog.y = 400;
    frog.width = 30;
    frog.height = 30;
    frog.speed = 2;

    while (1) {
        update_game();
        render_game();
        usleep(16000); // ~60 FPS
    }

    return 0;
}
